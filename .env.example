# =============================================================
# BetterScan — Variables de entorno (plantilla)
# Copiar a .env y rellenar valores reales.
# El INTERNAL_TOKEN debe ser el MISMO en Laravel y FastAPI.
# =============================================================
#
# AVISO DE SEGURIDAD
# ------------------
# Los valores que siguen son PLACEHOLDERS, NO contraseñas reales.
# Sirven para que el `docker-compose.yml` valide la sintaxis de la
# variable y para que se sepa qué campos tiene que rellenar.
# NO arranque ningún despliegue — ni siquiera local — con estos
# valores tal cual: el contenedor de MariaDB los aceptaría y crearía
# usuarios con esas claves, dejando información sensible expuesta
# si el `.env` se filtra (commit accidental, copia de seguridad
# pública, scraping de imágenes Docker, etc.). En la instancia
# pública desplegada en AWS los valores reales son distintos a los
# de este fichero, generados con `openssl rand -hex 24`.
#
# Para una instalación local mínima basta con sustituir los
# CAMBIAR_ME por contraseñas robustas con `openssl rand -hex 24`.

# --- Token compartido Laravel <-> FastAPI ---
# Generar con: openssl rand -hex 32
INTERNAL_TOKEN=CAMBIAR_ME_TOKEN_HEX_64_CHARS

# --- MariaDB ---
# Generar cada contraseña con: openssl rand -hex 24
DB_ROOT_PASSWORD=CAMBIAR_ME_ROOT_PASSWORD
DB_DATABASE=betterscan_db
DB_USER=betterscan_app
DB_PASSWORD=CAMBIAR_ME_APP_PASSWORD
DB_BACKUP_USER=betterscan_backup
DB_BACKUP_PASSWORD=CAMBIAR_ME_BACKUP_PASSWORD

# --- Laravel ---
APP_NAME=BetterScan
APP_ENV=local
APP_DEBUG=true
APP_URL=https://localhost
# APP_KEY la genera el entrypoint del contenedor automáticamente
# (php artisan key:generate). NO añadir aquí una APP_KEY vacía: la
# variable se inyectaría como entorno y Laravel la leería con prioridad
# sobre el .env del contenedor, abortando con MissingAppKeyException.

# --- FastAPI ---
FASTAPI_BASE_URL=http://fastapi-engine:8888
# Opcional: si dispones de API key de NVD (gratuita, da más rate limit)
# Solicitar en https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
